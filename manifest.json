{
  "manifest_version": 3,
  "name": "Conventional Comments for GitLab & GitHub",
  "version": "0.2.1",
  "description": "Shows a Conventional Comments dropdown when typing a trigger in merge request and pull request comment textareas.",
  "permissions": [
    "storage",
    "scripting",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "src/options.html",
  "action": {
    "default_title": "Conventional Comments"
  },
  "icons": {
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  }
}
