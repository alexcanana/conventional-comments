{
  "manifest_version": 3,
  "name": "Conventional Comments for GitLab & GitHub",
  "version": "0.1.3",
  "description": "Conventional Comments autocomplete in GitLab/GitHub MR and PR comment boxes (Chrome, Edge, Firefox).",
  "permissions": [
    "storage",
    "scripting",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Conventional Comments"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
